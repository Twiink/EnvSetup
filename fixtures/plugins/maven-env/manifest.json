{
  "id": "maven-env",
  "name": {
    "zh-CN": "Maven 构建环境",
    "en": "Maven Build Environment"
  },
  "version": "0.1.0",
  "mainAppVersion": "^0.1.0",
  "platforms": ["darwin", "win32"],
  "permissions": ["download", "write_path", "modify_env"],
  "parameters": {
    "mavenManager": {
      "type": "enum",
      "values": ["maven", "package"],
      "required": true
    },
    "mavenVersion": {
      "type": "version",
      "required": true
    },
    "installRootDir": {
      "type": "path",
      "required": true
    }
  },
  "dependencies": [],
  "entry": "index.ts"
}

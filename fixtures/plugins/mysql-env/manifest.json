{
  "id": "mysql-env",
  "name": {
    "zh-CN": "MySQL 数据库环境",
    "en": "MySQL Database Environment"
  },
  "version": "0.1.0",
  "mainAppVersion": "^0.2.4",
  "platforms": ["darwin", "win32"],
  "permissions": ["download", "write_path", "modify_env"],
  "parameters": {
    "mysqlManager": {
      "type": "enum",
      "values": ["mysql", "package"],
      "required": true
    },
    "mysqlVersion": {
      "type": "version",
      "required": false
    },
    "installRootDir": {
      "type": "path",
      "required": true
    }
  },
  "dependencies": [],
  "entry": "index.ts"
}

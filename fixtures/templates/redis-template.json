{
  "id": "redis-template",
  "name": {
    "zh-CN": "Redis 缓存环境",
    "en": "Redis Cache Environment"
  },
  "version": "0.1.0",
  "platforms": ["darwin", "win32"],
  "description": {
    "zh-CN": "支持 Redis 直装，macOS 使用 Redis 官方源码包，Windows 使用 Redis 官方合作方 Memurai 开发版；也支持平台包管理器安装：macOS 使用 Homebrew，Windows 使用 Scoop。",
    "en": "Install Redis directly using the official Redis source archive on macOS and the Redis partner Memurai Developer installer on Windows, or use the platform package manager: Homebrew on macOS and Scoop on Windows."
  },
  "plugins": [
    {
      "pluginId": "redis-env",
      "version": "0.1.0"
    }
  ],
  "defaults": {
    "redis.redisManager": "package",
    "redis.redisVersion": "7.4.7",
    "redis.installRootDir": "./.envsetup-data/toolchain"
  },
  "overrides": {
    "redis.redisManager": {
      "type": "enum",
      "editable": true,
      "required": true,
      "enum": ["redis", "package"],
      "affects": ["redis-env"]
    },
    "redis.redisVersion": {
      "type": "version",
      "editable": true,
      "required": true,
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "dependsOn": {
        "field": "redis.redisManager",
        "equals": "redis"
      },
      "affects": ["redis-env"]
    },
    "redis.installRootDir": {
      "type": "path",
      "editable": true,
      "required": true,
      "affects": ["redis-env"]
    }
  },
  "checks": ["redis"],
  "maintainer": {
    "zh-CN": "环境配置团队",
    "en": "Environment Setup Team"
  },
  "recommended": true
}

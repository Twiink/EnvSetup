{
  "id": "maven-template",
  "name": {
    "zh-CN": "Maven 构建环境",
    "en": "Maven Build Environment"
  },
  "version": "0.1.0",
  "platforms": ["darwin", "win32"],
  "description": {
    "zh-CN": "支持通过 Apache 官方二进制归档直装 Maven，也支持通过平台包管理器安装：macOS 使用 Homebrew，Windows 使用 Scoop。",
    "en": "Install Maven from the official Apache binary archive, or use the platform package manager: Homebrew on macOS and Scoop on Windows."
  },
  "plugins": [
    {
      "pluginId": "maven-env",
      "version": "0.1.0"
    }
  ],
  "defaults": {
    "maven.mavenManager": "maven",
    "maven.mavenVersion": "3.9.11",
    "maven.installRootDir": "./.envsetup-data/toolchain"
  },
  "overrides": {
    "maven.mavenManager": {
      "type": "enum",
      "editable": true,
      "required": true,
      "enum": ["maven", "package"],
      "affects": ["maven-env"]
    },
    "maven.mavenVersion": {
      "type": "version",
      "editable": true,
      "required": true,
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "maven.installRootDir": {
      "type": "path",
      "editable": true,
      "required": true,
      "affects": ["maven-env"]
    }
  },
  "checks": ["maven"],
  "maintainer": {
    "zh-CN": "环境配置团队",
    "en": "Environment Setup Team"
  },
  "recommended": true
}

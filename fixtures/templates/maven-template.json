{
  "id": "maven-template",
  "name": {
    "zh-CN": "Maven 构建环境",
    "en": "Maven Build Environment"
  },
  "version": "0.1.0",
  "platforms": ["darwin", "win32"],
  "description": {
    "zh-CN": "通过 Apache 官方二进制归档安装 Maven，并配置用户级环境变量。",
    "en": "Install Maven from the official Apache binary archive and configure user-level environment variables."
  },
  "plugins": [
    {
      "pluginId": "maven-env",
      "version": "0.1.0"
    }
  ],
  "defaults": {
    "maven.mavenManager": "maven",
    "maven.mavenVersion": "3.9.11",
    "maven.installRootDir": "./.envsetup-data/toolchain"
  },
  "overrides": {
    "maven.mavenManager": {
      "type": "enum",
      "editable": true,
      "required": true,
      "enum": ["maven"],
      "affects": ["maven-env"]
    },
    "maven.mavenVersion": {
      "type": "version",
      "editable": true,
      "required": true,
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "dependsOn": {
        "field": "maven.mavenManager",
        "equals": "maven"
      }
    },
    "maven.installRootDir": {
      "type": "path",
      "editable": true,
      "required": true,
      "affects": ["maven-env"]
    }
  },
  "checks": ["maven"],
  "maintainer": {
    "zh-CN": "环境配置团队",
    "en": "Environment Setup Team"
  },
  "recommended": true
}
